# Anthropic
ANTHROPIC_API_KEY=

# LangSmith
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=procure-agent
LANGSMITH_TRACING=true

# Database (Supabase Postgres — use the connection-pooler URL for serverless safety)
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/postgres

# Schema namespace inside the shared Supabase project
DATABASE_SCHEMA=procure_agent
