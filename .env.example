# procure-agent — environment variables
#
# Local dev: copy to .env and fill in. .env is gitignored.
# Railway: set the same keys per service via the dashboard.

# ---- API service (FastAPI + LangGraph) -------------------------------------

# Anthropic
ANTHROPIC_API_KEY=

# LangSmith
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=procure-agent
LANGSMITH_TRACING=true

# Database
# Local docker (see docker-compose.yml). Default below assumes the daemon and
# this process run on the same machine. If this process runs inside an
# OrbStack Linux VM and the docker daemon is on the Mac, use OrbStack's
# container DNS instead: postgresql://postgres:postgres@procure-pg.orb.local:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
# Railway-Postgres deploy (swap in for prod; Railway exposes a DATABASE_URL
# automatically when a Postgres plugin is attached to the service).

# Schema namespace inside the database (domain rows live here; LangGraph
# checkpoint tables stay in `public`).
DATABASE_SCHEMA=procure_agent

# Comma-separated CORS allowlist for the API. Local dev covers the Next.js
# port. In production, the web service proxies same-origin so this is only
# relevant if a recruiter pokes the API directly with a browser.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- Web service (Next.js) -------------------------------------------------

# Internal URL the Next.js service uses to reach the API service.
# Local dev: http://localhost:8000
# Railway:   http://${{api.RAILWAY_PRIVATE_DOMAIN}}:8000
API_INTERNAL_URL=http://localhost:8000
